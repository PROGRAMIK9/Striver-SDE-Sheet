/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public void inorderhelp(TreeNode root, List<Integer> inorder){
        if(root == null) return;
        inorderhelp(root.left, inorder);
        inorder.add(root.val);
        inorderhelp(root.right, inorder);
    }
    public int kthSmallest(TreeNode root, int k) {
        List<Integer> res = new ArrayList<>();
        inorderhelp(root, res);
        return res.get(k-1);
    }
}
